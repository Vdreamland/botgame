from utils.logger import logger

def log_ws_connecting(url: str):
    logger.info(f"[NETWORK] Mencoba terhubung ke WebSocket: {url}")

def log_ws_connected():
    logger.info("[NETWORK] Koneksi WebSocket berhasil dibuka.")

def log_ws_error(err: str):
    logger.error(f"[NETWORK] Kesalahan WebSocket: {err}")

def log_ws_send(data: dict):
    logger.info(f"[NETWORK] Mengirim pesan: {data}")

def log_ws_receive(data: str):
    preview = data if len(data) < 500 else data[:500] + "... [TERPOTONG]"
    logger.info(f"[NETWORK] Menerima pesan: {preview}")

def log_ws_closed():
    logger.warning("[NETWORK] Koneksi WebSocket ditutup.")